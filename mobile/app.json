{
  "expo": {
    "name": "Creveton",
    "slug": "creveton",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "creveton",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0b2e1a",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0b2e1a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cm.creveton.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "cm.creveton.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#d4a017"
      },
      "permissions": ["NOTIFICATIONS"],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b2e1a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0b2e1a",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Creveton accède à vos photos pour choisir une photo de profil.",
          "cameraPermission": "Creveton accède à l'appareil photo pour prendre une photo de profil."
        }
      ]
    ],
    "extra": {
      "eas": {}
    }
  }
}
