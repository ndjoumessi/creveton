{
  "expo": {
    "name": "Creveton",
    "slug": "creveton",
    "version": "1.0.0",
    "owner": "ndjoumessi",
    "privacy_policy_url": "https://creveton-admin-staging.up.railway.app/privacy",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "creveton",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0b2e1a",
    "updates": {
      "url": "https://u.expo.dev/9d8a0a53-32bf-4759-be3b-df6bfedf4822"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0b2e1a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cm.creveton.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "cm.creveton.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b2e1a"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b2e1a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0b2e1a",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Creveton accède à vos photos pour choisir une photo de profil.",
          "cameraPermission": "Creveton accède à l'appareil photo pour prendre une photo de profil.",
          "microphonePermission": false
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "9d8a0a53-32bf-4759-be3b-df6bfedf4822"
      }
    }
  }
}
