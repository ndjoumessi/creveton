# URL de base de l'API backend (voir ../backend). Préfixe EXPO_PUBLIC_ requis
# pour être exposé au bundle Expo.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# (Optionnel) URL du serveur socket.io (temps réel tournois). Par défaut
# dérivée de EXPO_PUBLIC_API_URL en retirant le suffixe /api/v1.
# EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
