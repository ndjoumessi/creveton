# URL de base de l'API backend Creveton.
# Le backend écoute par défaut sur le port 4000 (backend/src/config/env.js).
# Laisser vide pour utiliser le proxy Vite (/api → http://localhost:4000).
VITE_API_URL=http://localhost:4000/api/v1

# Mode démo (DÉVELOPPEMENT UNIQUEMENT) : true → l'app affiche des données mock
# quand le backend est injoignable. Sans effet sur un build de production
# (fail-closed : voir src/services/api.js). La connexion ne retombe sur la
# session démo que si le backend est réellement hors-ligne, jamais sur un
# refus d'authentification (401/403).
VITE_USE_MOCKS=true
