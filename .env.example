# ───────────────────────────────────────────────────────────────────────────
# Creveton — variables d'environnement (docker compose). Copier vers .env.
# JAMAIS de vraies valeurs ici : uniquement des clés et des placeholders.
# ───────────────────────────────────────────────────────────────────────────

# PostgreSQL (interpolé dans docker-compose : DATABASE_URL backend)
POSTGRES_PASSWORD=changeme

# Redis (interpolé dans docker-compose : REDIS_URL backend)
REDIS_PASSWORD=changeme

# Backend
NODE_ENV=production
PORT=4000
CORS_ORIGIN=*
# Secrets JWT — noms RÉELS lus par src/config/env.js (≥ 32 caractères en prod).
JWT_ACCESS_SECRET=changeme_min_32_chars________________
JWT_REFRESH_SECRET=changeme_min_32_chars________________
# Connexions (en compose, surchargées par le service backend avec les hôtes
# internes `postgres`/`redis` ; ces valeurs servent hors compose / documentation).
DATABASE_URL=postgresql://creveton:changeme@postgres:5432/creveton_dev
REDIS_URL=redis://:changeme@redis:6379

# Admin (figé au build de l'image Vite)
VITE_API_URL=http://localhost:4000/api/v1

# ── Optionnel (laisser vide si non utilisé) ────────────────────────────────
# Push « force_sync » via FCM (le push ciblé Expo n'exige aucune clé serveur).
# FCM_SERVER_KEY=
# FCM_PROJECT_ID=

# SMS / OTP (Twilio Verify)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# TWILIO_FROM_NUMBER=

# Mobile Money (flag tournaments.paid désactivé par défaut)
# ORANGE_MONEY_API_KEY=
# MTN_MOMO_API_KEY=
# CAMPAY_API_KEY=

# Email (TODO : brancher Resend/SMTP pour les invitations équipe)
# RESEND_API_KEY=
# FROM_EMAIL=noreply@creveton.cm
