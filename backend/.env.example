# ============================================================
# Creveton Backend — Variables d'environnement (exemple)
# Copier vers .env et renseigner les valeurs réelles.
# ============================================================

# --- Serveur ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Origines autorisées CORS (séparées par des virgules), ou * en dev
CORS_ORIGIN=*

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://creveton:creveton@localhost:5432/creveton
PGHOST=localhost
PGPORT=5432
PGUSER=creveton
PGPASSWORD=creveton
PGDATABASE=creveton
PG_SSL=false
PG_POOL_MAX=10

# --- Redis (cache, sessions tournoi, rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# --- Email transactionnel (Resend) ---
# Invitations équipe + parrainage joueur. Sans clé, les envois sont des no-op
# journalisés (le flux métier n'est jamais bloqué).
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Creveton <noreply@creveton.cm>
# Lien profond / store pour le parrainage joueur (?ref=CODE est ajouté)
APP_DEEP_LINK_URL=https://creveton.cm
# Base de la console admin pour les liens d'invitation (sinon ADMIN_BASE_URL / défaut)
ADMIN_URL=https://creveton-admin-staging.up.railway.app
# Limite d'invitations de parrainage par joueur et par jour
REFERRAL_LIMIT_PER_DAY=10

# --- OTP / SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_FROM_NUMBER=
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_LIMIT_PER_HOUR=5

# --- Feature flags ---
FEATURE_TOURNAMENTS_PAID_ENABLED=false

# --- Paiements Mobile Money (activés plus tard, derrière le flag) ---
# Orange Money
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=
# MTN MoMo
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
MTN_MOMO_WEBHOOK_SECRET=
# Campay
CAMPAY_API_KEY=
CAMPAY_API_SECRET=
CAMPAY_WEBHOOK_SECRET=

# --- Push notifications (FCM / APNs) ---
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# --- Rate limiting ---
RATE_LIMIT_PUBLIC_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=500

# --- Uploads (import questions CSV/Excel) ---
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads

# --- Cloudinary (stockage des avatars de profil) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Preset d'upload non signé (recadrage 200×200 défini dans le preset Cloudinary)
CLOUDINARY_UPLOAD_PRESET=creveton_avatar
